{"type":"item.completed","item":{"id":"item_37","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command 'rg -n \"''^\" \"lib/utils/date-helpers.ts\"'","aggregated_output":"1:/**\n2: * Get Monday of the week for a given date\n3: */\n4:export function getWeekStart(date: Date): Date {\n5:  const d = new Date(date)\n6:  const day = d.getDay()\n7:  const diff = d.getDate() - day + (day === 0 ? -6 : 1) // Monday\n8:  d.setDate(diff)\n9:  d.setHours(0, 0, 0, 0)\n10:  return d\n11:}\n12:\n13:/**\n14: * Get Sunday of the week for a given date\n15: */\n16:export function getWeekEnd(date: Date): Date {\n17:  const start = getWeekStart(date)\n18:  const end = new Date(start)\n19:  end.setDate(end.getDate() + 6)\n20:  return end\n21:}\n22:\n23:/**\n24: * Format date as DD/MM/YYYY (Vietnamese convention)\n25: */\n26:export function formatDate(date: Date | string): string {\n27:  const d = typeof date === \"string\" ? new Date(date) : date\n28:  return d.toLocaleDateString(\"vi-VN\", {\n29:    day: \"2-digit\",\n30:    month: \"2-digit\",\n31:    year: \"numeric\",\n32:  })\n33:}\n34:\n35:/**\n36: * Format date as YYYY-MM-DD (for database/API)\n37: */\n38:export function toISODate(date: Date): string {\n39:  return date.toISOString().split(\"T\")[0]\n40:}\n41:\n42:/**\n43: * Vietnamese day names (Monday=T2, ..., Sunday=CN)\n44: */\n45:export const VIETNAMESE_DAYS = [\n46:  \"CN\", // 0 = Sunday\n47:  \"T2\", // 1 = Monday\n48:  \"T3\", // 2 = Tuesday\n49:  \"T4\", // 3 = Wednesday\n50:  \"T5\", // 4 = Thursday\n51:  \"T6\", // 5 = Friday\n52:  \"T7\", // 6 = Saturday\n53:] as const\n54:\n55:/**\n56: * Convert day-of-week number (1=Mon...7=Sun) to Vietnamese name\n57: */\n58:export function getDayName(dayOfWeek: number): string {\n59:  const map: Record<number, string> = {\n60:    1: \"T2\",\n61:    2: \"T3\",\n62:    3: \"T4\",\n63:    4: \"T5\",\n64:    5: \"T6\",\n65:    6: \"T7\",\n66:    7: \"CN\",\n67:  }\n68:  return map[dayOfWeek] ?? \"\"\n69:}\n70:\n71:/**\n72: * Get all dates in a week (Mon-Sun) for a given week start\n73: */\n74:export function getWeekDates(weekStart: Date): Date[] {\n75:  return Array.from({ length: 7 }, (_, i) => {\n76:    const d = new Date(weekStart)\n77:    d.setDate(d.getDate() + i)\n78:    return d\n79:  })\n80:}\n81:\n82:/**\n83: * Get month name in Vietnamese\n84: */\n85:export function getMonthName(month: number): string {\n86:  return `Tháng ${month}`\n87:}\n88:\n89:/**\n90: * Format week range: \"02/03 - 08/03/2026\"\n91: */\n92:export function formatWeekRange(weekStart: Date): string {\n93:  const end = getWeekEnd(weekStart)\n94:  const startStr = weekStart.toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit' })\n95:  const endStr = formatDate(end)\n96:  return `${startStr} - ${endStr}`\n97:}\n98:\n99:/**\n100: * Check if a week is auto-locked (> 3 days past next Monday)\n101: */\n102:export function isWeekLocked(weekStart: Date): boolean {\n103:  const nextMonday = new Date(weekStart)\n104:  nextMonday.setDate(nextMonday.getDate() + 10) // week end (7) + 3 grace days\n105:  return new Date() > nextMonday\n106:}\n107:\n108:/**\n109: * Convert ISO day-of-week (1=Mon..7=Sun) to JS Date.getDay() (0=Sun..6=Sat)\n110: */\n111:export function isoToJsDay(isoDay: number): number {\n112:  return isoDay === 7 ? 0 : isoDay\n113:}\n114:\n115:/**\n116: * Convert JS Date.getDay() (0=Sun..6=Sat) to ISO day-of-week (1=Mon..7=Sun)\n117: */\n118:export function jsDayToIso(jsDay: number): number {\n119:  return jsDay === 0 ? 7 : jsDay\n120:}\n121:\n122:/**\n123: * Get ISO day-of-week for a Date\n124: */\n125:export function getIsoDay(date: Date): number {\n126:  return jsDayToIso(date.getDay())\n127:}\nCannot set property. Property setting is supported only on core types in this language mode.\r\nAt line:1 char:1\r\n+ [Console]::OutputEncoding=[System.Text.Encoding]::UTF8;\r\n+ ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\r\n    + Cat