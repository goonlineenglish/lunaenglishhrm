us: newStatus } }\n42:      updated[rowIdx] = row\n43:\n44:      const key = `${row.employeeId}:${day}`\n45:      const original = initialRows[rowIdx]?.cells[day]?.status ?? null\n46:      setDirty((prev) => {\n47:        const next = new Map(prev)\n48:        if (newStatus === original) next.delete(key)\n49:        else next.set(key, { status: newStatus, original })\n50:        return next\n51:      })\n52:\n53:      return updated\n54:    })\n55:  }, [initialRows])\n56:\n57:  async function handleSave() {\n58:    setSaving(true)\n59:    setError(null)\n60:\n61:    const items: OfficeSaveItem[] = []\n62:    for (const [key, val] of dirty) {\n63:      const [employeeId, dayStr] = key.split(':')\n64:      const day = parseInt(dayStr)\n65:      const dateStr = toISODate(weekDates[day - 1])\n66:      const row = rows.find((r) => r.employeeId === employeeId)\n67:      const existingId = row?.cells[day]?.existingId ?? null\n68:      items.push({ branchId, employeeId, date: dateStr, status: val.status, existingId })\n69:    }\n70:\n71:    const result = await saveOfficeAttendanceBatch(items)\n72:    setSaving(false)\n73:\n74:    if (!result.success) {\n75:      setError(result.error ?? 'Lỗi lưu.')\n76:      return\n77:    }\n78:    setDirty(new Map())\n79:    onSaved()\n80:  }\n81:\n82:  if (rows.length === 0) {\n83:    return (\n84:      <div className=\"text-center py-8 text-muted-foreground border rounded-md\">\n85:        Chưa có nhân viên VP nào cho chi nhánh này.\n86:      </div>\n87:    )\n88:  }\n89:\n90:  return (\n91:    <div className=\"space-y-3\">\n92:      {error && <Alert variant=\"destructive\"><p className=\"text-sm\">{error}</p></Alert>}\n93:\n94:      <div className=\"overflow-auto rounded-md border\">\n95:        <table className=\"w-full text-sm\">\n96:          <thead>\n97:            <tr className=\"bg-muted/50\">\n98:              <th className=\"px-2 py-2 text-left border\">Mã NV</th>\n99:              <th className=\"px-2 py-2 text-left border\">Tên</th>\n100:              {DAYS.map((d) => (\n101:                <th key={d} className=\"px-1 py-2 text-center border w-10\">{getDayName(d)}</th>\n102:              ))}\n103:            </tr>\n104:          </thead>\n105:          <tbody>\n106:            {rows.map((row, rowIdx) => (\n107:              <tr key={row.employeeId} className=\"hover:bg-muted/30\">\n108:                <td className=\"px-2 py-1 border text-xs font-medium\">{row.employeeCode}</td>\n109:                <td className=\"px-2 py-1 border text-xs max-w-[150px] truncate\">{row.employeeName}</td>\n110:                {DAYS.map((d) => {\n111:                  const cell = row.cells[d] as OfficeGridCell\n112:                  return (\n113:                    <AttendanceCell\n114:                      key={d}\n115:                      status={cell.status}\n116:                      isScheduled={cell.isWorkDay}\n117:                      disabled={isLocked}\n118:                      onChange={(s) => handleChange(rowIdx, d, s)}\n119:                    />\n120:                  )\n121:                })}\n122:              </tr>\n123:            ))}\n124:          </tbody>\n125:        </table>\n126:      </div>\n127:\n128:      {!isLocked && (\n129:        <Button onClick={handleSave} disabled={dirty.size === 0 || saving} size=\"sm\">\n130:          <Save className=\"h-4 w-4 mr-1\" />\n131:          {saving ? 'Đang lưu...' : `Lưu (${dirty.size} thay đổi)`}\n132:        </Button>\n133:      )}\n134:    </div>\n135:  )\n136:}\nCannot set property. Property setting is supported only on core types in this language mode.\r\nAt line:1 char:1\r\n+ [Console]::OutputEncoding=[System.Text.Encoding]::UTF8;\r\n+ ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\r\n    + CategoryInfo          : InvalidOperation: (:) [], RuntimeException\r\n    + FullyQualifiedErrorId : PropertySetterNotSupportedInConstrainedLanguage\r\n \r\n","exit_code":0,"status":"completed"}}
