rt, isAccountant, onRefresh }: Props) {\n51:  const [showForm, setShowForm] = useState(false)\n52:  const [noteType, setNoteType] = useState<NoteType>('general')\n53:  const [employeeId, setEmployeeId] = useState('')\n54:  const [employeeCode, setEmployeeCode] = useState('')\n55:  const [description, setDescription] = useState('')\n56:  const [amount, setAmount] = useState('')\n57:  const [amountUnit, setAmountUnit] = useState<'sessions' | 'vnd'>('sessions')\n58:  const [saving, setSaving] = useState(false)\n59:  const [error, setError] = useState<string | null>(null)\n60:\n61:  function handleEmployeeSelect(emp: EmployeeLookup) {\n62:    setEmployeeId(emp.id)\n63:    setEmployeeCode(emp.employee_code)\n64:  }\n65:\n66:  async function handleAdd() {\n67:    if (!employeeId || !description.trim()) {\n68:      setError('Chọn NV và nhập mô tả.')\n69:      return\n70:    }\n71:\n72:    setSaving(true)\n73:    setError(null)\n74:\n75:    const result = await createWeeklyNote({\n76:      branch_id: branchId,\n77:      week_start: weekStart,\n78:      employee_id: employeeId,\n79:      note_type: noteType,\n80:      description: description.trim(),\n81:      amount: amount ? parseFloat(amount) : null,\n82:      amount_unit: amount ? amountUnit : null,\n83:    })\n84:\n85:    setSaving(false)\n86:    if (!result.success) {\n87:      setError(result.error ?? 'Lỗi tạo ghi chú.')\n88:      return\n89:    }\n90:\n91:    // Reset form\n92:    setDescription('')\n93:    setAmount('')\n94:    setEmployeeId('')\n95:    setEmployeeCode('')\n96:    setShowForm(false)\n97:    onRefresh()\n98:  }\n99:\n100:  async function handleDelete(id: string) {\n101:    if (!confirm('Xoá ghi chú này?')) return\n102:    const result = await deleteWeeklyNote(id)\n103:    if (!result.success) alert(result.error ?? 'Lỗi xoá.')\n104:    else onRefresh()\n105:  }\n106:\n107:  async function handleProcess(id: string) {\n108:    const result = await markNoteProcessed(id)\n109:    if (!result.success) alert(result.error ?? 'Lỗi duyệt.')\n110:    else onRefresh()\n111:  }\n112:\n113:  return (\n114:    <div className=\"space-y-3\">\n115:      <div className=\"flex items-center justify-between\">\n116:        <h3 className=\"font-semibold text-sm\">Ghi chú tuần</h3>\n117:        {!isAccountant && (\n118:          <Button size=\"sm\" variant=\"outline\" onClick={() => setShowForm(!showForm)}>\n119:            <Plus className=\"h-3 w-3 mr-1\" />\n120:            Thêm ghi chú\n121:          </Button>\n122:        )}\n123:      </div>\n124:\n125:      {error && <Alert variant=\"destructive\"><p className=\"text-xs\">{error}</p></Alert>}\n126:\n127:      {/* Add note form */}\n128:      {showForm && (\n129:        <div className=\"border rounded-md p-3 space-y-2 bg-muted/30\">\n130:          <div className=\"grid grid-cols-2 gap-2\">\n131:            <div>\n132:              <Label className=\"text-xs\">Nhân viên</Label>\n133:              <EmployeeCodeLookup value={employeeCode} onSelect={handleEmployeeSelect} placeholder=\"Mã NV\" />\n134:            </div>\n135:            <div>\n136:              <Label className=\"text-xs\">Loại</Label>\n137:              <Select value={noteType} onValueChange={(v) => setNoteType(v as NoteType)}>\n138:                <SelectTrigger><SelectValue /></SelectTrigger>\n139:                <SelectContent>\n140:                  {(Object.entries(NOTE_TYPE_LABELS) as [NoteType, string][]).map(([k, v]) => (\n141:                    <SelectItem key={k} value={k}>{v}</SelectItem>\n142:                  ))}\n143:                </SelectContent>\n144:              </Select>\n145:            </div>\n146:          </div>\n147:          <div>\n148:            <Label className=\"text-xs\">Mô tả</Label>\n149:            <Input value={description} onChange={(e) => setDescription(e.target.value)} placeholder=\"Nội dung ghi chú\" />\n150:          </div>\n151:          <div className=\"grid grid-cols-2 gap-2\">\n152:            <div>\n153:              <Label className=\"text-xs\">Số lượng (tuỳ chọn)</Label>\n154:              <Input type=\"number\" value={amount} onChange={(e) => setAmount(e.target.value)} placeholder=\"0\" />\n155:            </div>\n156:            <div>\n157:              <Label className=\"text-xs\">Đơn vị</Label>\n158:              <Select value={amountUnit} onValueChange={(v) => setAmountUnit(v as 'sessions' | 'vnd')}>\n159:                <SelectTrigger><SelectValue /></SelectTrigger>\n160:                <SelectContent>\n161:                  <SelectItem value=\"sessions\">Buổi</SelectItem>\n162:                  <SelectItem value=\"vnd\">VNĐ</SelectItem>\n163:                </SelectContent>\n164:              </Select>\n165:            </div>\n166:          </div>\n167:          <Button size=\"sm\" onClick={handleAdd} disabled={saving}>\n168:            {saving ? 'Đang lưu...' : 'Thêm'}\n169:          </Button>\n170:        </div>\n171:      )}\n172:\n173:      {/* Notes list */}\n174:      {notes.length === 0 ? (\n175:        <p className=\"text-xs text-muted-foreground\">Chưa có ghi chú.</p>\n176:      ) : (\n177:        <div className=\"space-y-1\">\n178:          {notes.map((n) => (\n179:            <div key={n.id} className=\"flex items-start justify-between px-2 py-1.5 rounded border text-xs\">\n180:              <div className=\"flex-1\">\n181:                <div className=\"flex items-center gap-2\">\n182:                  <Badge variant=\"outline\" className={`text-xs ${NOTE_TYPE_COLORS[n.note_type]}`}>\n183:                    {NOTE_TYPE_LABELS[n.note_type]}\n184:                  </Badge>\n185:                  <span className=\"font-medium\">{n.employee_code}</span>\n186:                  <span className=\"text-muted-foreground\">{n.employee_name}</span>\n187:                  {n.is_processed && <CheckCircle className=\"h-3 w-3 text-green-600\" />}\n188:                </div>\n189:                <p className=\"mt-0.5\">{n.description}</p>\n190:                {n.amount && (\n191:                  <span className=\"text-muted-foreground\">\n192:                    {n.amount} {n.amount_unit === 'vnd' ? 'VNĐ' : 'buổi'}\n193:                  </span>\n194:                )}\n195:              </div>\n196:              <div className=\"flex gap-1 ml-2\">\n197:                {isAccountant && !n.is_processed && (\n198:                  <Button size=\"icon\" variant=\"ghost\" onClick={() => handleProcess(n.id)} title=\"Duyệt\">\n199:                    <CheckCircle className=\"h-3 w-3\" />\n200:                  </Button>\n201:                )}\n202:                {!isAccountant && (\n203:                  <Button size=\"icon\" variant=\"ghost\" onClick={() => handleDelete(n.id)} title=\"Xoá\">\n204:                    <Trash2 className=\"h-3 w-3 text-destructive\" />\n205:                  </Button>\n206:                )}\n207:              </div>\n208:            </div>\n209:          ))}\n210:        </div>\n211:      )}\n212:    </div>\n213:  )\n214:}\nCannot set property. Property setting is supported only on core types in this language mode.\r\nAt line:1 char:1\r\n+ [Console]::OutputEncoding=[System.Text.Encoding]::UTF8;\r\n+ ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\r\n    + CategoryInfo          : InvalidOperation: (:) [], RuntimeException\r\n    + FullyQualifiedErrorId : PropertySetterNotSupportedInConstrainedLanguage\r\n \r\n","exit_code":0,"status":"completed"}}
