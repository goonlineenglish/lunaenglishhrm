{"type":"item.completed","item":{"id":"item_16","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command 'rg -n \"''^\" \"lib/services/attendance-grid-service.ts\"'","aggregated_output":"1:/**\n2: * Attendance grid generation service.\n3: * Converts class_schedules + existing attendance records into a grid model\n4: * that the UI renders as rows × columns (T2-CN).\n5: */\n6:\n7:import type { AttendanceStatus } from '@/lib/types/database'\n8:\n9:// ─── Grid types ──────────────────────────────────────────────────────────────\n10:\n11:export interface AttendanceCell {\n12:  status: AttendanceStatus | null\n13:  isScheduled: boolean\n14:  existingId: string | null // attendance row ID if already saved\n15:}\n16:\n17:export interface AttendanceGridRow {\n18:  scheduleId: string\n19:  classCode: string\n20:  className: string\n21:  shiftTime: string\n22:  role: 'GV' | 'TG'\n23:  employeeId: string\n24:  employeeCode: string\n25:  employeeName: string\n26:  /** Map of ISO day (1=Mon..7=Sun) → cell state */\n27:  cells: Record<number, AttendanceCell>\n28:}\n29:\n30:export interface ScheduleConflict {\n31:  employeeId: string\n32:  employeeCode: string\n33:  employeeName: string\n34:  day: number\n35:  shiftTime: string\n36:  classes: string[]\n37:}\n38:\n39:export interface WeekSummary {\n40:  employeeId: string\n41:  employeeCode: string\n42:  employeeName: string\n43:  totalPresent: number\n44:  totalAbsent: number\n45:  totalKP: number\n46:  totalHalf: number\n47:  totalSessions: number // 1 + 0.5\n48:}\n49:\n50:// ─── Raw DB row shapes ──────────────────────────────────────────────────────\n51:\n52:interface ScheduleRow {\n53:  id: string\n54:  class_code: string\n55:  class_name: string\n56:  shift_time: string\n57:  days_of_week: number[]\n58:  teacher_id: string\n59:  assistant_id: string\n60:  teacher: { employee_code: string; full_name: string } | null\n61:  assistant: { employee_code: string; full_name: string } | null\n62:}\n63:\n64:interface AttendanceRow {\n65:  id: string\n66:  schedule_id: string\n67:  employee_id: string\n68:  date: string\n69:  status: AttendanceStatus\n70:}\n71:\n72:// ─── Grid generation ────────────────────────────────────────────────────────\n73:\n74:/** Build the attendance grid from schedules + existing records */\n75:export function buildAttendanceGrid(\n76:  schedules: ScheduleRow[],\n77:  existingRecords: AttendanceRow[],\n78:  weekDates: Date[]\n79:): AttendanceGridRow[] {\n80:  // Index existing records by \"scheduleId:employeeId:date\"\n81:  const recordMap = new Map<string, AttendanceRow>()\n82:  for (const rec of existingRecords) {\n83:    const key = `${rec.schedule_id}:${rec.employee_id}:${rec.date}`\n84:    recordMap.set(key, rec)\n85:  }\n86:\n87:  const rows: AttendanceGridRow[] = []\n88:\n89:  for (const sched of schedules) {\n90:    // Teacher row\n91:    if (sched.teacher_id) {\n92:      rows.push(buildRow(sched, 'GV', sched.teacher_id,\n93:        sched.teacher?.employee_code ?? '?',\n94:        sched.teacher?.full_name ?? '—',\n95:        weekDates, recordMap))\n96:    }\n97:    // Assistant row\n98:    if (sched.assistant_id) {\n99:      rows.push(buildRow(sched, 'TG', sched.assistant_id,\n100:        sched.assistant?.employee_code ?? '?',\n101:        sched.assistant?.full_name ?? '—',\n102:        weekDates, recordMap))\n103:    }\n104:  }\n105:\n106:  return rows\n107:}\n108:\n109:function buildRow(\n110:  sched: ScheduleRow,\n111:  role: 'GV' | 'TG',\n112:  employeeId: string,\n113:  employeeCode: string,\n114:  employeeName: string,\n115:  weekDates: Date[],\n116:  recordMap: Map<string, AttendanceRow>\n117:): AttendanceGridRow {\n118:  const cells: Record<number, AttendanceCell> = {}\n119:\n120:  for (let i = 0; i < 7; i++) {\n121:    const isoDay = i + 1 // 1=Mon..7=Sun\n122:    const isScheduled = sched.days_of_week.includes(isoDay)\n123:    const dateStr = weekDates[i].toISOString().split('T')[0]\n124:    const key = `${sched.id}:${employeeId}:${dateStr}`\n125:    const existing = recordMap.get(key)\n126:\n127:    cells[isoDay] = {\n128:      status: existing ? existing.status : (isScheduled ? '1' : null),\n129:      isScheduled,\n130:      existingId: existing?.id ?? null,\n131:    }\n132:  }\n133:\n134:  return {\n135:    scheduleId: sched.id,\n136:    classCode: sched.class_code,\n137:    className: sched.class_name,\n138:    shiftTime: sched.shift_time,\n139:    role,\n140:    employeeId,\n141:    employeeCode,\n142:    employeeName,\n143:    cells,\n144:  }\n145:}\n146:\n147:// ─── Conflict detection ─────────────────────────────────────────────────────\n148:\n149:/** Find employees scheduled in 2+ classes at same shift_time on same day */\n150:export function detectConflicts(schedules: ScheduleRow[]): ScheduleConflict[] {\n151:  // Map: \"employeeId:shiftTime:day\" → class_codes[]\n152:  const map = new Map<string, { codes: string[]; empCode: string; empName: string }>()\n153:\n154:  for (const sched of schedules) {\n155:    const pairs = [\n156:      { id: sched.teacher_id, code: sched.teacher?.employee_code ?? '?', name: sched.teacher?.full_name ?? '—' },\n157:      { id: sched.assistant_id, code: sched.assistant?.employee_code ?? '?', name: sched.assistant?.full_name ?? '—' },\n158:    ]\n159:\n160:    for (const emp of pairs) {\n161:      if (!emp.id) continue\n162:      for (const day of sched.days_of_week) {\n163:        const key = `${emp.id}:${sched.shift_time}:${day}`\n164:        const entry = map.get(key) ?? { codes: [], empCode: emp.code, empName: emp.name }\n165:        entry.codes.push(sched.class_code)\n166:        map.set(key, entry)\n167:      }\n168:    }\n169:  }\n170:\n171:  const conflicts: ScheduleConflict[] = []\n172:  for (const [key, val] of map) {\n173:    if (val.codes.length > 1) {\n174:      const [employeeId, shiftTime, dayStr] = key.split(':')\n175:      conflicts.push({\n176:        employeeId,\n177:        employeeCode: val.empCode,\n178:        employeeName: val.empName,\n179:        day: parseInt(dayStr),\n180:        shiftTime,\n181:        classes: val.codes,\n182:      })\n183:    }\n184:  }\n185:\n186:  return conflicts\n187:}\n188:\n189:// ─── Week summary ───────────────────────────────────────────────────────────\n190:\n191:/** Calculate per-employee totals from grid rows */\n192:export function calculateWeekSummary(rows: AttendanceGridRow[]): WeekSummary[] {\n193:  const map = new Map<string, WeekSummary>()\n194:\n195:  for (const row of rows) {\n196:    let summary = map.get(row.employeeId)\n197:    if (!summary) {\n198:      summary = {\n199:        employeeId: row.employeeId,\n200:        employeeCode: row.employeeCode,\n201:        employeeName: row.employeeName,\n202:        totalPresent: 0, totalAbsent: 0, totalKP: 0, totalHalf: 0, totalSessions: 0,\n203:      }\n204:      map.set(row.employeeId, summary)\n205:    }\n206:\n207:    for (const cell of Object.values(row.cells)) {\n208:      if (!cell.isScheduled || !cell.status) continue\n209:      switch (cell.status) {\n210:        case '1':    summary.totalPresent++; summary.totalSessions++; break\n211:        case '0':    summary.totalAbsent++; break\n212:        case 'KP':   summary.totalKP++; break\n213:        case '0.5':  summary.totalHalf++; summary.totalSessions += 0.5; break\n214:      }\n215:    }\n216:  }\n217:\n218:  return Array.from(map.values())\n219:}\nCannot set property. Property setting is supported only on core types in this language mode.\r\nAt line:1 char:1\r\n+ [Console]::OutputEncoding=[System.Text.Encoding]::UTF8;\r\n+ ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\r\n    + CategoryInfo          : InvalidOperation: (:) [], RuntimeException\r\n    + FullyQualifiedErrorId : PropertySetterNotSupportedInConstrainedLanguage\r\n \r\n","exit_code":0,"status":"completed"}}
