{"type":"item.completed","item":{"id":"item_14","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command 'rg -n \"''^\" \"lib/actions/office-attendance-actions.ts\"'","aggregated_output":"1:'use server'\n2:\n3:import { createClient } from '@/lib/supabase/server'\n4:import { getCurrentUser } from '@/lib/actions/auth-actions'\n5:import { getWeekDates, toISODate } from '@/lib/utils/date-helpers'\n6:import type { AttendanceStatus } from '@/lib/types/database'\n7:\n8:export interface ActionResult<T = void> {\n9:  success: boolean\n10:  data?: T\n11:  error?: string\n12:}\n13:\n14:// ─── Office attendance grid types ───────────────────────────────────────────\n15:\n16:export interface OfficeGridCell {\n17:  status: AttendanceStatus | null\n18:  isWorkDay: boolean\n19:  existingId: string | null\n20:}\n21:\n22:export interface OfficeGridRow {\n23:  employeeId: string\n24:  employeeCode: string\n25:  employeeName: string\n26:  cells: Record<number, OfficeGridCell> // ISO day 1-7\n27:}\n28:\n29:export interface OfficeGridData {\n30:  rows: OfficeGridRow[]\n31:  isLocked: boolean\n32:}\n33:\n34:// ─── Get office attendance grid ─────────────────────────────────────────────\n35:\n36:export async function getOfficeAttendanceGrid(\n37:  branchId: string,\n38:  weekStartStr: string\n39:): Promise<ActionResult<OfficeGridData>> {\n40:  try {\n41:    const user = await getCurrentUser()\n42:    if (!user) return { success: false, error: 'Chưa đăng nhập.' }\n43:\n44:    const canView = user.role === 'admin' || user.role === 'branch_manager'\n45:    if (!canView) return { success: false, error: 'Bạn không có quyền xem chấm công VP.' }\n46:\n47:    const effectiveBranch = user.role === 'branch_manager' ? user.branch_id! : branchId\n48:    const supabase = await createClient()\n49:    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n50:    const sb = supabase as any\n51:\n52:    // Fetch VP (office) employees for branch\n53:    const { data: employees, error: empErr } = await sb\n54:      .from('employees')\n55:      .select('id, employee_code, full_name')\n56:      .eq('branch_id', effectiveBranch)\n57:      .eq('position', 'office')\n58:      .eq('is_active', true)\n59:      .order('employee_code')\n60:    if (empErr) throw empErr\n61:\n62:    if (!employees || employees.length === 0) {\n63:      return { success: true, data: { rows: [], isLocked: false } }\n64:    }\n65:\n66:    const weekStart = new Date(weekStartStr)\n67:    const weekDates = getWeekDates(weekStart)\n68:    const dateFrom = toISODate(weekDates[0])\n69:    const dateTo = toISODate(weekDates[6])\n70:    const empIds = employees.map((e: { id: string }) => e.id)\n71:\n72:    // Fetch existing office_attendance records\n73:    const { data: records, error: recErr } = await sb\n74:      .from('office_attendance')\n75:      .select('id, employee_id, date, status')\n76:      .in('employee_id', empIds)\n77:      .gte('date', dateFrom)\n78:      .lte('date', dateTo)\n79:    if (recErr) throw recErr\n80:\n81:    // Index existing records\n82:    const recMap = new Map<string, { id: string; status: AttendanceStatus }>()\n83:    for (const r of (records ?? []) as { id: string; employee_id: string; date: string; status: AttendanceStatus }[]) {\n84:      recMap.set(`${r.employee_id}:${r.date}`, { id: r.id, status: r.status })\n85:    }\n86:\n87:    // Check lock\n88:    const { data: lockData } = await sb\n89:      .from('attendance_locks')\n90:      .select('id')\n91:      .eq('branch_id', effectiveBranch)\n92:      .eq('week_start', dateFrom)\n93:      .maybeSingle()\n94:\n95:    // Build grid rows\n96:    const rows: OfficeGridRow[] = (employees as { id: string; employee_code: string; full_name: string }[]).map((emp) => {\n97:      const cells: Record<number, OfficeGridCell> = {}\n98:      for (let i = 0; i < 7; i++) {\n99:        const isoDay = i + 1\n100:        const isWorkDay = isoDay >= 1 && isoDay <= 6 // Mon-Sat\n101:        const dateStr = toISODate(weekDates[i])\n102:        const existing = recMap.get(`${emp.id}:${dateStr}`)\n103:\n104:        cells[isoDay] = {\n105:          status: existing ? existing.status : (isWorkDay ? '1' : null),\n106:          isWorkDay,\n107:          existingId: existing?.id ?? null,\n108:        }\n109:      }\n110:      return {\n111:        employeeId: emp.id,\n112:        employeeCode: emp.employee_code,\n113:        employeeName: emp.full_name,\n114:        cells,\n115:      }\n116:    })\n117:\n118:    return { success: true, data: { rows, isLocked: !!lockData } }\n119:  } catch (err) {\n120:    console.error('[getOfficeAttendanceGrid]', err)\n121:    return { success: false, error: 'Không thể tải chấm công VP.' }\n122:  }\n123:}\n124:\n125:// ─── Save office attendance batch ───────────────────────────────────────────\n126:\n127:export interface OfficeSaveItem {\n128:  branchId: string\n129:  employeeId: string\n130:  date: string\n131:  status: AttendanceStatus\n132:  existingId?: string | null\n133:}\n134:\n135:export async function saveOfficeAttendanceBatch(\n136:  records: OfficeSaveItem[]\n137:): Promise<ActionResult> {\n138:  try {\n139:    const user = await getCurrentUser()\n140:    if (!user) return { success: false, error: 'Chưa đăng nhập.' }\n141:\n142:    const canEdit = user.role === 'admin' || user.role === 'branch_manager'\n143:    if (!canEdit) return { success: false, error: 'Bạn không có quyền lưu chấm công VP.' }\n144:\n145:    if (records.length === 0) return { success: true }\n146:\n147:    const supabase = await createClient()\n148:    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n149:    const sb = supabase as any\n150:\n151:    const toInsert = records.filter((r) => !r.existingId).map((r) => ({\n152:      branch_id: r.branchId || (user.role === 'branch_manager' ? user.branch_id : r.branchId),\n153:      employee_id: r.employeeId,\n154:      date: r.date,\n155:      status: r.status,\n156:      marked_by: user.id,\n157:    }))\n158:\n159:    const toUpdate = records.filter((r) => r.existingId)\n160:\n161:    if (toInsert.length > 0) {\n162:      const { error: insErr } = await sb.from('office_attendance').insert(toInsert)\n163:      if (insErr) throw insErr\n164:    }\n165:\n166:    for (const rec of toUpdate) {\n167:      const { error: updErr } = await sb\n168:        .from('office_attendance')\n169:        .update({ status: rec.status, marked_by: user.id })\n170:        .eq('id', rec.existingId)\n171:      if (updErr) throw updErr\n172:    }\n173:\n174:    return { success: true }\n175:  } catch (err) {\n176:    console.error('[saveOfficeAttendanceBatch]', err)\n177:    return { success: false, error: 'Không thể lưu chấm công VP.' }\n178:  }\n179:}\nCannot set property. Property setting is supported only on core types in this language mode.\r\nAt line:1 char:1\r\n+ [Console]::OutputEncoding=[System.Text.Encoding]::UTF8;\r\n+ ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\r\n    + CategoryInfo          : InvalidOperation: (:) [], RuntimeException\r\n    + FullyQualifiedErrorId : PropertySetterNotSupportedInConstrainedLanguage\r\n \r\n","exit_code":0,"status":"completed"}}
