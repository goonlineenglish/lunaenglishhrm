interface Props {
  initialStudents: StudentWithLead[];
  initialCount: number;
}

export function StudentsClient({ initialStudents, initialCount }: Props) {
  const [students, setStudents] = useState(initialStudents);
  const [count, setCount] = useState(initialCount);
