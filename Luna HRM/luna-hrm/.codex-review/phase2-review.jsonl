{"type":"item.completed","item":{"id":"item_31","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command 'rg -n \"''^\" \"app/api/cron/weekly-reminder/route.ts\"'","aggregated_output":"1:/**\n2: * Weekend reminder cron — triggered Saturday evening.\n3: * Checks which branches have unsaved attendance for current week.\n4: * Secured with CRON_SECRET header.\n5: */\n6:\n7:import { NextRequest, NextResponse } from 'next/server'\n8:import { createAdminClient } from '@/lib/supabase/admin'\n9:import { getWeekStart, toISODate } from '@/lib/utils/date-helpers'\n10:\n11:export async function GET(request: NextRequest) {\n12:  // Verify cron secret\n13:  const secret = request.headers.get('x-cron-secret')\n14:  if (secret !== process.env.CRON_SECRET) {\n15:    return NextResponse.json({ error: 'Unauthorized' }, { status: 401 })\n16:  }\n17:\n18:  try {\n19:    const admin = createAdminClient()\n20:    const weekStart = toISODate(getWeekStart(new Date()))\n21:\n22:    // Get all active branches\n23:    const { data: branches, error: brErr } = await admin\n24:      .from('branches')\n25:      .select('id, name')\n26:      .eq('is_active', true)\n27:    if (brErr) throw brErr\n28:\n29:    // Check which branches have locks for this week\n30:    const { data: locks, error: lockErr } = await admin\n31:      .from('attendance_locks')\n32:      .select('branch_id')\n33:      .eq('week_start', weekStart)\n34:    if (lockErr) throw lockErr\n35:\n36:    const lockedBranchIds = new Set((locks ?? []).map((l: { branch_id: string }) => l.branch_id))\n37:    const unsaved = (branches ?? []).filter((b: { id: string }) => !lockedBranchIds.has(b.id))\n38:\n39:    if (unsaved.length > 0) {\n40:      console.log('[weekly-reminder] Branches without saved attendance:', unsaved.map((b: { name: string }) => b.name))\n41:      // Future: send notification to branch managers\n42:    }\n43:\n44:    return NextResponse.json({\n45:      success: true,\n46:      week: weekStart,\n47:      unsaved_count: unsaved.length,\n48:      unsaved_branches: unsaved.map((b: { name: string }) => b.name),\n49:    })\n50:  } catch (err) {\n51:    console.error('[weekly-reminder]', err)\n52:    return NextResponse.json({ error: 'Internal error' }, { status: 500 })\n53:  }\n54:}\nCannot set property. Property setting is supported only on core types in this language mode.\r\nAt line:1 char:1\r\n+ [Console]::OutputEncoding=[System.Text.Encoding]::UTF8;\r\n+ ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\r\n    + CategoryInfo          : InvalidOperation: (:) [], RuntimeException\r\n    + FullyQualifiedErrorId : PropertySetterNotSupportedInConstrainedLanguage\r\n \r\n","exit_code":0,"status":"completed"}}
