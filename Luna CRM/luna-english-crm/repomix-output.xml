const UUID_RE = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;

export interface CreateLeadInput {
  parent_name: string;
  parent_phone: string;
  source: LeadSource;
  program_interest?: ProgramType | null;
  student_name?: string | null;
  notes?: string | null;
}

export interface UpdateLeadInput {
  parent_name?: string;
  parent_phone?: string;
