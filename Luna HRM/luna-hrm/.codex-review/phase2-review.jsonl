{"type":"item.completed","item":{"id":"item_26","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command 'rg -n \"''^\" \"components/attendance/attendance-grid.tsx\"'","aggregated_output":"1:'use client'\n2:\n3:/**\n4: * Weekly class-based attendance grid.\n5: * Rows = class × position (GV/TG), columns = T2-CN.\n6: * Tracks dirty cells in state, shows diff before batch save.\n7: */\n8:\n9:import { useState, useCallback } from 'react'\n10:import { Save, Lock } from 'lucide-react'\n11:import { Button } from '@/components/ui/button'\n12:import { Alert } from '@/components/ui/alert'\n13:import { AttendanceCell } from './attendance-cell'\n14:import { AttendanceDiffDialog, type DiffItem } from './attendance-diff-dialog'\n15:import { saveAttendanceBatch, lockWeek, type AttendanceSaveItem } from '@/lib/actions/attendance-actions'\n16:import type { AttendanceGridRow, AttendanceCell as CellType } from '@/lib/services/attendance-grid-service'\n17:import type { AttendanceStatus } from '@/lib/types/database'\n18:import { getDayName, getWeekDates, toISODate } from '@/lib/utils/date-helpers'\n19:\n20:const DAYS = [1, 2, 3, 4, 5, 6, 7] // Mon..Sun\n21:\n22:interface Props {\n23:  initialRows: AttendanceGridRow[]\n24:  branchId: string\n25:  weekStart: Date\n26:  isLocked: boolean\n27:  onSaved: () => void\n28:}\n29:\n30:// Track changed cells: \"scheduleId:employeeId:day\" → newStatus\n31:type DirtyMap = Map<string, { status: AttendanceStatus; originalStatus: AttendanceStatus | null }>\n32:\n33:export function AttendanceGrid({ initialRows, branchId, weekStart, isLocked, onSaved }: Props) {\n34:  const [rows, setRows] = useState<AttendanceGridRow[]>(initialRows)\n35:  const [dirty, setDirty] = useState<DirtyMap>(new Map())\n36:  const [diffOpen, setDiffOpen] = useState(false)\n37:  const [saving, setSaving] = useState(false)\n38:  const [error, setError] = useState<string | null>(null)\n39:\n40:  const weekDates = getWeekDates(weekStart)\n41:\n42:  const handleCellChange = useCallback((\n43:    rowIdx: number, day: number, newStatus: AttendanceStatus\n44:  ) => {\n45:    setRows((prev) => {\n46:      const updated = [...prev]\n47:      const row = { ...updated[rowIdx] }\n48:      const cell = { ...row.cells[day] }\n49:      const originalStatus = initialRows[rowIdx]?.cells[day]?.status ?? null\n50:\n51:      cell.status = newStatus\n52:      row.cells = { ...row.cells, [day]: cell }\n53:      updated[rowIdx] = row\n54:\n55:      // Track dirty\n56:      const key = `${row.scheduleId}:${row.employeeId}:${day}`\n57:      setDirty((prev) => {\n58:        const next = new Map(prev)\n59:        if (newStatus === originalStatus) {\n60:          next.delete(key)\n61:        } else {\n62:          next.set(key, { status: newStatus, originalStatus })\n63:        }\n64:        return next\n65:      })\n66:\n67:      return updated\n68:    })\n69:  }, [initialRows])\n70:\n71:  function buildDiffs(): DiffItem[] {\n72:    const diffs: DiffItem[] = []\n73:    for (const [key, val] of dirty) {\n74:      const [, , dayStr] = key.split(':')\n75:      // Find the row to get employee info\n76:      const row = rows.find((r) => key.startsWith(`${r.scheduleId}:${r.employeeId}:`))\n77:      if (row) {\n78:        diffs.push({\n79:          employeeCode: row.employeeCode,\n80:          employeeName: row.employeeName,\n81:          day: parseInt(dayStr),\n82:          oldStatus: val.originalStatus,\n83:          newStatus: val.status,\n84:        })\n85:      }\n86:    }\n87:    return diffs\n88:  }\n89:\n90:  function buildSaveItems(): AttendanceSaveItem[] {\n91:    const items: AttendanceSaveItem[] = []\n92:    for (const [key, val] of dirty) {\n93:      const [scheduleId, employeeId, dayStr] = key.split(':')\n94:      const day = parseInt(dayStr)\n95:      const dateStr = toISODate(weekDates[day - 1])\n96:      // Find existing ID\n97:      const row = rows.find((r) => r.scheduleId === scheduleId && r.employeeId === employeeId)\n98:      const existingId = row?.cells[day]?.existingId ?? null\n99:\n100:      items.push({ scheduleId, employeeId, date: dateStr, status: val.status, existingId })\n101:    }\n102:    return items\n103:  }\n104:\n105:  async function handleSave() {\n106:    setSaving(true)\n107:    setError(null)\n108:    const items = buildSaveItems()\n109:    const result = await saveAttendanceBatch(items)\n110:    setSaving(false)\n111:    setDiffOpen(false)\n112:\n113:    if (!result.success) {\n114:      setError(result.error ?? 'Lỗi lưu chấm công.')\n115:      return\n116:    }\n117:\n118:    setDirty(new Map())\n119:    onSaved()\n120:  }\n121:\n122:  async function handleLock() {\n123:    if (!confirm('Khoá tuần này? Sau khi khoá sẽ không chỉnh sửa được.')) return\n124:    const dateStr = toISODate(weekStart)\n125:    const result = await lockWeek(branchId, dateStr)\n126:    if (!result.success) alert(result.error ?? 'Lỗi khoá tuần.')\n127:    else onSaved()\n128:  }\n129:\n130:  if (rows.length === 0) {\n131:    return (\n132:      <div className=\"text-center py-8 text-muted-foreground border rounded-md\">\n133:        Chưa có lịch lớp nào cho chi nhánh này.\n134:      </div>\n135:    )\n136:  }\n137:\n138:  return (\n139:    <div className=\"space-y-3\">\n140:      {error && <Alert variant=\"destructive\"><p className=\"text-sm\">{error}</p></Alert>}\n141:\n142:      <div className=\"overflow-auto rounded-md border\">\n143:        <table className=\"w-full text-sm\">\n144:          <thead>\n145:            <tr className=\"bg-muted/50\">\n146:              <th className=\"px-2 py-2 text-left border\">Lớp</th>\n147:              <th className=\"px-2 py-2 text-left border\">Ca</th>\n148:              <th className=\"px-1 py-2 text-center border w-10\">VT</th>\n149:              <th className=\"px-2 py-2 text-left border\">Mã</th>\n150:              <th className=\"px-2 py-2 text-left border\">Tên</th>\n151:              {DAYS.map((d) => (\n152:                <th key={d} className=\"px-1 py-2 text-center border w-10\">{getDayName(d)}</th>\n153:              ))}\n154:            </tr>\n155:          </thead>\n156:          <tbody>\n157:            {rows.map((row, rowIdx) => (\n158:              <tr key={`${row.scheduleId}-${row.role}`} className=\"hover:bg-muted/30\">\n159:                <td className=\"px-2 py-1 border text-xs font-medium\">{row.classCode}</td>\n160:                <td className=\"px-2 py-1 border text-xs\">{row.shiftTime}</td>\n161:                <td className=\"px-1 py-1 text-center border text-xs font-medium\">\n162:                  <span className={row.role === 'GV' ? 'text-primary' : 'text-orange-600'}>\n163:                    {row.role}\n164:                  </span>\n165:                </td>\n166:                <td className=\"px-2 py-1 border text-xs\">{row.employeeCode}</td>\n167:                <td className=\"px-2 py-1 border text-xs max-w-[120px] truncate\">{row.employeeName}</td>\n168:                {DAYS.map((d) => {\n169:                  const cell = row.cells[d] as CellType\n170:                  return (\n171:                    <AttendanceCell\n172:                      key={d}\n173:                      status={cell.status}\n174:                      isScheduled={cell.isScheduled}\n175:                      disabled={isLocked}\n176:                      onChange={(s) => handleCellChange(rowIdx, d, s)}\n177:                    />\n178:                  )\n179:                })}\n180:              </tr>\n181:            ))}\n182:          </tbody>\n183:        </table>\n184:      </div>\n185:\n186:      {/* Action buttons */}\n187:      {!isLocked && (\n188:        <div className=\"flex gap-2\">\n189:          <Button onClick={() => setDiffOpen(true)} disabled={dirty.size === 0} size=\"sm\">\n190:            <Save className=\"h-4 w-4 mr-1\" />\n191:            Lưu tuần ({dirty.size} thay đổi)\n192:          </Button>\n193:          <Button variant=\"outline\" onClick={handleLock} size=\"sm\">\n194:            <Lock className=\"h-4 w-4 mr-1\" />\n195:            Khoá tuần\n196:          </Button>\n197:        </div>\n198:      )}\n199:\n200:      {isLocked && (\n201:        <p className=\"text-sm text-destructive flex items-center gap-1\">\n202:          <Lock className=\"h-4 w-4\" /> Tuần này đã khoá, không thể chỉnh sửa.\n203:        </p>\n204:      )}\n205:\n206:      <AttendanceDiffDialog\n207:        open={diffOpen}\n208:        onOpenChange={setDiffOpen}\n209:        diffs={buildDiffs()}\n210:        saving={saving}\n211:        onConfirm={handleSave}\n212:      />\n213:    </div>\n214:  )\n215:}\nCannot set property. Property setting is supported only on core types in this language mode.\r\nAt line:1 char:1\r\n+ [Console]::OutputEncoding=[System.Text.Encoding]::UTF8;\r\n+ ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\r\n    + CategoryInfo          : InvalidOperation: (:) [], RuntimeException\r\n    + FullyQualifiedErrorId : PropertySetterNotSupportedInConstrainedLanguage\r\n \r\n","exit_code":0,"status":"completed"}}
