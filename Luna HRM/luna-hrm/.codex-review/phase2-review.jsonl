ules_assistant_id_fkey(full_name)')\n49:      .order('class_code')\n50:\n51:    if (effectiveBranch) query = query.eq('branch_id', effectiveBranch)\n52:    if (status) query = query.eq('status', status)\n53:\n54:    const { data, error } = await query\n55:    if (error) throw error\n56:\n57:    type RawRow = ClassSchedule & {\n58:      teacher: { full_name: string } | null\n59:      assistant: { full_name: string } | null\n60:    }\n61:    const rows = ((data ?? []) as RawRow[]).map((r) => ({\n62:      ...r,\n63:      teacher_name: r.teacher?.full_name ?? '—',\n64:      assistant_name: r.assistant?.full_name ?? '—',\n65:      teacher: undefined,\n66:      assistant: undefined,\n67:    }))\n68:\n69:    return { success: true, data: rows }\n70:  } catch (err) {\n71:    console.error('[getClassSchedules]', err)\n72:    return { success: false, error: 'Không thể tải lịch lớp.' }\n73:  }\n74:}\n75:\n76:// ─── Create class schedule ──────────────────────────────────────────────────\n77:\n78:export async function createClassSchedule(\n79:  data: ClassScheduleInsert\n80:): Promise<ActionResult<ClassSchedule>> {\n81:  try {\n82:    const user = await getCurrentUser()\n83:    if (!user) return { success: false, error: 'Chưa đăng nhập.' }\n84:\n85:    const canCreate = user.role === 'admin' || user.role === 'branch_manager'\n86:    if (!canCreate) return { success: false, error: 'Bạn không có quyền tạo lịch lớp.' }\n87:\n88:    // BM: force own branch\n89:    const branchId = user.role === 'branch_manager' ? user.branch_id! : data.branch_id\n90:\n91:    const supabase = await createClient()\n92:    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n93:    const sb = supabase as any\n94:\n95:    const { data: schedule, error } = await sb\n96:      .from('class_schedules')\n97:      .insert({ ...data, branch_id: branchId })\n98:      .select()\n99:      .single()\n100:\n101:    if (error) throw error\n102:    return { success: true, data: schedule as ClassSchedule }\n103:  } catch (err: unknown) {\n104:    console.error('[createClassSchedule]', err)\n105:    const msg = err instanceof Error ? err.message : ''\n106:    if (msg.includes('unique') || msg.includes('duplicate')) {\n107:      return { success: false, error: 'Mã lớp đã tồn tại trong chi nhánh này.' }\n108:    }\n109:    return { success: false, error: 'Không thể tạo lịch lớp.' }\n110:  }\n111:}\n112:\n113:// ─── Update class schedule ──────────────────────────────────────────────────\n114:\n115:export async function updateClassSchedule(\n116:  id: string,\n117:  data: ClassScheduleUpdate\n118:): Promise<ActionResult<ClassSchedule>> {\n119:  try {\n120:    const user = await getCurrentUser()\n121:    if (!user) return { success: false, error: 'Chưa đăng nhập.' }\n122:\n123:    const canEdit = user.role === 'admin' || user.role === 'branch_manager'\n124:    if (!canEdit) return { success: false, error: 'Bạn không có quyền sửa lịch lớp.' }\n125:\n126:    const supabase = await createClient()\n127:    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n128:    const sb = supabase as any\n129:\n130:    const { data: schedule, error } = await sb\n131:      .from('class_schedules')\n132:      .update(data)\n133:      .eq('id', id)\n134:      .select()\n135:      .single()\n136:\n137:    if (error) throw error\n138:    return { success: true, data: schedule as ClassSchedule }\n139:  } catch (err) {\n140:    console.error('[updateClassSchedule]', err)\n141:    return { success: false, error: 'Không thể cập nhật lịch lớp.' }\n142:  }\n143:}\n144:\n145:// ─── Deactivate class schedule ──────────────────────────────────────────────\n146:\n147:export async function deactivateClassSchedule(\n148:  id: string\n149:): Promise<ActionResult> {\n150:  try {\n151:    const user = await getCurrentUser()\n152:    if (!user) return { success: false, error: 'Chưa đăng nhập.' }\n153:\n154:    const canEdit = user.role === 'admin' || user.role === 'branch_manager'\n155:    if (!canEdit) return { success: false, error: 'Bạn không có quyền ngừng lớp.' }\n156:\n157:    const supabase = await createClient()\n158:    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n159:    const sb = supabase as any\n160:\n161:    const { error } = await sb\n162:      .from('class_schedules')\n163:      .update({ status: 'inactive' })\n164:      .eq('id', id)\n165:\n166:    if (error) throw error\n167:    return { success: true }\n168:  } catch (err) {\n169:    console.error('[deactivateClassSchedule]', err)\n170:    return { success: false, error: 'Không thể ngừng lớp.' }\n171:  }\n172:}\n173:\n174:// ─── Employee code lookup ───────────────────────────────────────────────────\n175:\n176:/** Lookup employee by code (partial match). Branch-scoped for BM. */\n177:export async function lookupEmployeeByCode(\n178:  code: string,\n179:  position?: Employee['position']\n180:): Promise<ActionResult<EmployeeLookup[]>> {\n181:  try {\n182:    const user = await getCurrentUser()\n183:    if (!user) return { success: false, error: 'Chưa đăng nhập.' }\n184:\n185:    const supabase = await createClient()\n186:    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n187:    const sb = supabase as any\n188:\n189:    let query = sb\n190:      .from('employees')\n191:      .select('id, employee_code, full_name, position, rate_per_session')\n192:      .eq('is_active', true)\n193:      .ilike('employee_code', `%${code}%`)\n194:      .order('employee_code')\n195:      .limit(10)\n196:\n197:    if (user.role === 'branch_manager' && user.branch_id) {\n198:      query = query.eq('branch_id', user.branch_id)\n199:    }\n200:    if (position) query = query.eq('position', position)\n201:\n202:    const { data, error } = await query\n203:    if (error) throw error\n204:    return { success: true, data: (data ?? []) as EmployeeLookup[] }\n205:  } catch (err) {\n206:    console.error('[lookupEmployeeByCode]', err)\n207:    return { success: false, error: 'Không thể