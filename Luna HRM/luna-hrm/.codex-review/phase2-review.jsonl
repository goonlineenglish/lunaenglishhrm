ve' as const,\n101:    }\n102:\n103:    const result = editSchedule\n104:      ? await updateClassSchedule(editSchedule.id, payload)\n105:      : await createClassSchedule(payload)\n106:\n107:    setSaving(false)\n108:    if (!result.success) return setError(result.error ?? 'Lỗi lưu lịch lớp.')\n109:\n110:    onOpenChange(false)\n111:    onSaved()\n112:  }\n113:\n114:  return (\n115:    <Dialog open={open} onOpenChange={onOpenChange}>\n116:      <DialogContent className=\"max-w-lg\">\n117:        <DialogHeader>\n118:          <DialogTitle>{editSchedule ? 'Sửa lịch lớp' : 'Thêm lịch lớp'}</DialogTitle>\n119:        </DialogHeader>\n120:        <form onSubmit={handleSave} className=\"space-y-4 py-2\">\n121:          {error && <Alert variant=\"destructive\"><p className=\"text-sm\">{error}</p></Alert>}\n122:\n123:          <div className=\"grid grid-cols-2 gap-3\">\n124:            <div className=\"space-y-1\">\n125:              <Label>Mã lớp *</Label>\n126:              <Input value={form.class_code} onChange={(e) => setForm((f) => ({ ...f, class_code: e.target.value }))} placeholder=\"IELTS-A1\" />\n127:            </div>\n128:            <div className=\"space-y-1\">\n129:              <Label>Tên lớp *</Label>\n130:              <Input value={form.class_name} onChange={(e) => setForm((f) => ({ ...f, class_name: e.target.value }))} placeholder=\"IELTS Band 5.0\" />\n131:            </div>\n132:          </div>\n133:\n134:          <div className=\"space-y-1\">\n135:            <Label>Ca học *</Label>\n136:            <Input value={form.shift_time} onChange={(e) => setForm((f) => ({ ...f, shift_time: e.target.value }))} placeholder=\"19:00-20:30\" />\n137:          </div>\n138:\n139:          <div className=\"space-y-1\">\n140:            <Label>Ngày học *</Label>\n141:            <div className=\"flex gap-2 flex-wrap\">\n142:              {DAYS.map((d) => (\n143:                <button\n144:                  key={d}\n145:                  type=\"button\"\n146:      