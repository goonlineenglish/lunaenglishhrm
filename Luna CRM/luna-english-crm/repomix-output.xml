export async function queryTotalLeads(
  supabase: SupabaseClient,
  dateRange: DateRange
): Promise<number> {
  const { count } = await supabase
    .from("leads")
    .select("*", { count: "exact", head: true })
    .gte("created_at", dateRange.from.toISOString())
    .lte("created_at", dateRange.to.toISOString());
